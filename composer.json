{
  "name": "ronu/laravel-federated-auth",
  "description": "Configurable Laravel federated authentication bridge for social providers, OAuth2/OIDC providers and enterprise identity systems such as Keycloak.",
  "type": "library",
  "version": "1.1.2",
  "license": "MIT",
  "keywords": [
    "laravel",
    "oauth2",
    "openid-connect",
    "oidc",
    "keycloak",
    "socialite",
    "federated-auth",
    "identity-broker"
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0|^12.0",
    "illuminate/contracts": "^11.0|^12.0",
    "illuminate/http": "^11.0|^12.0",
    "illuminate/routing": "^11.0|^12.0",
    "illuminate/database": "^11.0|^12.0",
    "laravel/socialite": "^5.15",
    "guzzlehttp/guzzle": "^7.8",
    "firebase/php-jwt": "^6.10"
  },
  "suggest": {
    "ronu/rest-generic-class": "Optional integration for REST-style response formatting and effective permission payloads.",
    "ronu/laravel-app-context": "Bind TokenIssuerInterface to Integrations\\AppContext\\AppContextTokenIssuer to emit channel-bound JWTs (aud/tid/did) accepted by app-context middleware.",
    "php-open-source-saver/jwt-auth": "Required by the JwtAuthTokenIssuer and by the app-context integration."
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "phpunit/phpunit": "^11.0",
    "laravel/pint": "^1.18"
  },
  "autoload": {
    "psr-4": {
      "Ronu\\LaravelFederatedAuth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Ronu\\LaravelFederatedAuth\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "@php vendor/bin/phpunit",
    "test:unit": "@php vendor/bin/phpunit --testsuite Unit",
    "pint": "@php vendor/bin/pint",
    "pint:test": "@php vendor/bin/pint --test",
    "format": "@pint",
    "qa": [
      "@pint:test",
      "@test"
    ]
  },
  "extra": {
    "laravel": {
      "providers": [
        "Ronu\\LaravelFederatedAuth\\FederatedAuthServiceProvider"
      ],
      "aliases": {
        "FederatedAuth": "Ronu\\LaravelFederatedAuth\\Facades\\FederatedAuth"
      }
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "php-http/discovery": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
